# Techviora static SPA — Hostinger / Apache
# Minimal rules: shared hosts often return 403 if .htaccess uses
# "Options" or "Header" without the right AllowOverride (Options/FileInfo).

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# If the site loads but /gulf breaks on refresh, mod_rewrite is off — contact Hostinger.
# After the site works, you can try cache headers in hPanel → Advanced → Custom rules
# instead of here, if you want long-lived caching for /static/*.
